# Copy to .env and fill in real values before running `docker compose up`.
# Generate ENCRYPTION_KEY with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Generate JWT_SECRET with:      node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

JWT_SECRET=replace-with-long-random-hex
ENCRYPTION_KEY=replace-with-64-char-hex
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
CORS_ORIGINS=http://localhost:3000
REACT_APP_API_URL=http://localhost:4000
